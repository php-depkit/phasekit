{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@depkit/phasekit-core": ["./packages/core/src/index.ts"],
      "@depkit/phasekit-opencode": ["./packages/opencode/src/adapter.ts"],
      "@depkit/phasekit-install": ["./packages/install/src/index.ts"],
      "*": ["./*"]
    },
    "types": ["bun"]
  },
  "include": ["packages/**/*.ts"]
}
