{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@phasekit/core": ["packages/core/src/index.ts"],
      "@phasekit/opencode": ["packages/opencode/src/adapter.ts"],
      "@phasekit/install": ["packages/install/src/index.ts"]
    },
    "types": ["bun"]
  },
  "include": ["packages/**/*.ts"]
}
