{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "plugins": [
    "node-workspace"
  ],
  "packages": {
    "packages/core": {
      "release-type": "node",
      "package-name": "@depkit/phasekit-core",
      "include-v-in-tag": true,
      "include-component-in-tag": true,
      "component": "phasekit-core"
    },
    "packages/opencode": {
      "release-type": "node",
      "package-name": "@depkit/phasekit-opencode",
      "include-v-in-tag": true,
      "include-component-in-tag": true,
      "component": "phasekit-opencode"
    },
    "packages/install": {
      "release-type": "node",
      "package-name": "@depkit/phasekit-install",
      "include-v-in-tag": true,
      "include-component-in-tag": true,
      "component": "phasekit-install"
    }
  }
}
