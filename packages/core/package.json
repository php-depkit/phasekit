{
  "name": "@depkit/phasekit-core",
  "version": "0.0.0",
  "type": "module",
  "description": "Harness-agnostic Phasekit core for planning, orchestration, verification, and artifact generation.",
  "license": "MIT",
  "dependencies": {
    "zod": "^3.25.76"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/depkit/phasekit.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/depkit/phasekit/issues"
  },
  "homepage": "https://github.com/depkit/phasekit#readme",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist",
    "prepack": "bun run build"
  }
}
