{
  "name": "@depkit/phasekit-opencode",
  "version": "1.0.0",
  "type": "module",
  "description": "OpenCode plugin adapter and managed artifact installer for Phasekit.",
  "license": "MIT",
  "main": "./dist/adapter.js",
  "types": "./dist/adapter.d.ts",
  "exports": {
    ".": {
      "types": "./dist/adapter.d.ts",
      "import": "./dist/adapter.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    }
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.15.0",
    "@depkit/phasekit-core": "1.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/php-depkit/phasekit.git",
    "directory": "packages/opencode"
  },
  "bugs": {
    "url": "https://github.com/php-depkit/phasekit/issues"
  },
  "homepage": "https://github.com/php-depkit/phasekit#readme",
  "scripts": {
    "build": "tsup src/adapter.ts src/plugin.ts --format esm --dts --clean --out-dir dist",
    "prepack": "bun run build"
  }
}
